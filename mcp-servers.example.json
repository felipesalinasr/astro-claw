{
  "apify": {
    "command": "npx",
    "args": ["-y", "@apify/actors-mcp-server"],
    "env": {
      "APIFY_TOKEN": "your-apify-token-here"
    }
  },
  "airtable": {
    "command": "npx",
    "args": ["-y", "airtable-mcp-server"],
    "env": {
      "AIRTABLE_API_KEY": "your-airtable-pat-here"
    }
  }
}
